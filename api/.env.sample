# Central source of truth for /api configuration.
# Runtime Go code, YAML config expansion, and Docker Compose all read from here.
# Shell or Compose-provided env values still override file values when already set.

# --------------------------------------------------------------------
# Runtime bootstrap
# --------------------------------------------------------------------
APP_ENV=docker

APP_NAME=noah_api
LOG_LEVEL=info
GOFLAGS=-mod=mod
GOCACHE=/app/.gocache
STORAGE_ROOT=/app/storage
GATEWAY_MODE=false

# --------------------------------------------------------------------
# App config
# --------------------------------------------------------------------
PROJECT_NAME=noah
BASE_API_PREFIX=/api
API_VERSION=v1

HOST=0.0.0.0
PORT=7999
BODY_LIMIT_MB=50

JWT_TOKEN_SECRET=
INTERNAL_AUTH_TOKEN=
AUTH_LOG_TOKEN=

RETRY_MAX_ATTEMPTS=3
RETRY_DELAY=100ms

DB_PROVIDER=postgres
DB_AUTOMIGRATE=true

PG_HOST=postgres
PG_PORT=5431
PG_USER=postgres
PG_PASSWORD=
PG_DBNAME=noahdb
PG_SSL=disable

MONGO_URI=
MONGO_DATABASE=

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DBNAME=

CACHE_TTL_SHORT=2m
CACHE_TTL_MEDIUM=5m
CACHE_TTL_LONG=20m
CACHE_TTL_STATIC=6h

REDIS_HOST=redis
REDIS_PORT=6378
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_CACHE_DB=0
REDIS_PUBSUB_DB=1
REDIS_STATUS_DB=2
REDIS_IS_CLUSTER=false
REDIS_USE_TLS=false

CB_INTERVAL=30s
CB_TIMEOUT=10s
CB_CONSECUTIVE_FAILURES=5

OBSERVABILITY_SERVICE_NAME=noah_api
OBSERVABILITY_LOGS_ENABLED=true
OBSERVABILITY_LOG_LEVEL=info

LOKI_BASE_URL=http://loki:3100
LOKI_TENANT_ID=
LOKI_BEARER_TOKEN=
LOKI_TIMEOUT=5s
LOKI_STREAM_SELECTOR={app="noah_api"}
LOKI_MAX_QUERY_LIMIT=200

# --------------------------------------------------------------------
# Cron config
# --------------------------------------------------------------------
CRON_CLEAR_REFRESH_TOKEN_ENABLED=true
CRON_CLEAR_REFRESH_TOKEN_SCHEDULE=@every 1h
CRON_CLEAR_DELETED_PHOTO_ENABLED=true
CRON_CLEAR_DELETED_PHOTO_SCHEDULE=0 0 * * *
CRON_EXPIRE_ORDER_CODE_ENABLED=true
CRON_EXPIRE_ORDER_CODE_SCHEDULE=@every 17m
CRON_CLEAR_EXPIRED_ORDER_CODE_ENABLED=true
CRON_CLEAR_EXPIRED_ORDER_CODE_SCHEDULE=5 0 * * *
CRON_DASHBOARD_CASE_DAILY_STATS_ENABLED=true
CRON_DASHBOARD_CASE_DAILY_STATS_SCHEDULE=10 0 * * *
CRON_DASHBOARD_CASE_DAILY_REMAKE_STATS_ENABLED=true
CRON_DASHBOARD_CASE_DAILY_REMAKE_STATS_SCHEDULE=11 0 * * *
CRON_DASHBOARD_CASE_DAILY_COMPLETED_STATS_ENABLED=true
CRON_DASHBOARD_CASE_DAILY_COMPLETED_STATS_SCHEDULE=12 0 * * *
CRON_DASHBOARD_CASE_DAILY_ACTIVE_STATS_ENABLED=true
CRON_DASHBOARD_CASE_DAILY_ACTIVE_STATS_SCHEDULE=13 0 * * *

# --------------------------------------------------------------------
# Module config
# --------------------------------------------------------------------
M_AUTH_HOST=127.0.0.1
M_AUTH_PORT=8083

M_RBAC_HOST=127.0.0.1
M_RBAC_PORT=8082

PHOTO_STORAGE_PATH=${STORAGE_ROOT}/photo

M_MAIN_HOST=127.0.0.1
M_MAIN_PORT=8078
M_MAIN_DELIVERY_QR_SESSION_TTL_MINUTES=5
M_MAIN_DELIVERY_QR_PROOF_IMAGE_MAX_SIZE_MB=5
M_MAIN_CLIENT_BASE_URL=http://localhost:5173

M_METADATA_HOST=127.0.0.1
M_METADATA_PORT=8079

M_USER_HOST=127.0.0.1
M_USER_PORT=8081

M_ATTRIBUTE_HOST=127.0.0.1
M_ATTRIBUTE_PORT=8090

M_AUDITLOG_HOST=127.0.0.1
M_AUDITLOG_PORT=8085

M_PROFILE_HOST=127.0.0.1
M_PROFILE_PORT=8084

M_TOKEN_HOST=127.0.0.1
M_TOKEN_PORT=8088

M_FOLDER_HOST=127.0.0.1
M_FOLDER_PORT=8091

M_PHOTO_HOST=127.0.0.1
M_PHOTO_PORT=8092

M_REALTIME_HOST=127.0.0.1
M_REALTIME_PORT=8096

M_NOTIFICATION_HOST=127.0.0.1
M_NOTIFICATION_PORT=8097

M_OBSERVABILITY_HOST=127.0.0.1
M_OBSERVABILITY_PORT=8097

M_SEARCH_HOST=127.0.0.1
M_SEARCH_PORT=1

# --------------------------------------------------------------------
# Docker Compose service env
# --------------------------------------------------------------------
PGDATA_DIR=./.data/postgres
REDISDATA_DIR=./.data/redis
